{
  "devMode": false,
  "ignoreCodeBlockRestrictions": false,
  "preferredDateFormat": "YYYY-MM-DD",
  "firstWeekday": {
    "index": 1,
    "name": "Monday",
    "shortName": "Mo"
  },
  "syncInterval": 200,
  "enableJs": true,
  "viewFieldDisplayNullAsEmpty": false,
  "enableSyntaxHighlighting": true,
  "enableEditorRightClickMenu": true,
  "inputFieldTemplates": [
    {
      "name": "mondo",
      "declaration": "INPUT[suggester(optionQuery(\"Mondi\"), useLinks(partial), allowOther)]"
    },
    {
      "name": "campagne",
      "declaration": "INPUT[inlineListSuggester(optionQuery(\"Campagne\"), useLinks(partial))]"
    },
    {
      "name": "canonico",
      "declaration": "INPUT[toggle]"
    },
    {
      "name": "stato base",
      "declaration": "INPUT[inlineSelect(option(bozza, Bozza), option(pronto, Pronto), option(in gioco, In Gioco), option(archiviata, Archiviata))]"
    },
    {
      "name": "stato canonico",
      "declaration": "INPUT[inlineSelect(option(canonico, Canonico), option(rumor, Rumor), option(leggenda, Leggenda), option(falso, Falso), option(retcon, Retcon))]"
    }
  ],
