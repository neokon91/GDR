{% macro calendario(range=false) -%}
> [!abstract]- Calendario
> {{ 'Inizio' if range else 'Data' }}: {{ field('fc-date', label=false) }} — nel formato del calendario attivo (Gregorian: AAAA-MM-GG).
{% if range %}
>
