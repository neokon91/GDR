{# Emette un campo editabile dal registro core.fields.
   field('id')              -> "Label: `INPUT[...]`"
   field('id', label=false) -> "`INPUT[...]`" (solo widget, label altrove)
   Va importato con contesto: {% import '_macros.j2' as m with context %} #}
{% macro field(id, label=true) -%}
{%- set f = core.fields[id] -%}
{%- if label %}{{ f.label }}: {% endif -%}
{%- if f.widget in ['text', 'number'] -%}`INPUT[{{ f.widget }}:{{ id }}]`
{%- else -%}`INPUT[{{ f.widget }}][:{{ id }}]`{%- endif -%}
{%- endmacro %}

{# Rende i campi 'body' del wizard (core.creation[categoria]) come callout
   editabili (pre-compilati dal wizard nel frontmatter). #}
{% macro wizard_body(category) -%}
{% set wiz = core.get('creation', {}).get(category, {}) %}
{% for q in wiz.get('body', []) %}
> [!{{ q.get('callout', 'note') }}]{{ '-' if q.get('fold') else '' }} {{ q.get('title') or q.get('heading') or q.field }}
> `INPUT[textArea:{{ q.field }}]`

{% endfor %}
{%- endmacro %}

{# --- Campi SOLA-LETTURA / CALCOLATI (Meta Bind VIEW) ------------------------
   Controparte read-only di field()/INPUT. Mostrano un valore senza renderlo
   editabile: utili per infobox/intestazioni che riflettono il frontmatter
   (modificato altrove). Modello: FantasyWorld JINJA/components/macro.jinja. #}

{# view('mondo') -> `VIEW[{mondo} ?? "—"]` — mostra il valore (math), "—" se vuoto. #}
{% macro view(path) -%}
`VIEW[{{ "{" ~ path ~ "}" }} ?? "—"]`
{%- endmacro %}

{# view_md('mondo') -> rende il markdown del valore (link [[..]], grassetto...). #}
{% macro view_md(path) -%}
`VIEW[{{ "{" ~ path ~ "}" }}][text(renderMarkdown)]`
{%- endmacro %}

{# Campo calcolato sola-lettura da un'espressione Meta Bind.
   computed('floor(({pressione}) / 2)') -> `VIEW[floor(({pressione}) / 2)]`.
   Riferimenti alle proprieta' tra graffe: {prop}, annidati {a.b.c}.
   Supporta ternari/confronti, es:
   computed('{pressione} >= 7 ? "Crisi" : ({pressione} >= 4 ? "Tensione" : "Calma")') #}
{% macro computed(expr) -%}
`VIEW[{{ expr }}]`
{%- endmacro %}

{# Come computed ma SALVA il risultato in 'dest' (VIEW[expr][math:dest]).
   compute_into('{forza} - 10', 'mod_forza'). #}
{% macro compute_into(expr, dest) -%}
`VIEW[{{ expr }}][math:{{ dest }}]`
{%- endmacro %}

{# === COMPONENTI CONDIVISI (DRY) =============================================
