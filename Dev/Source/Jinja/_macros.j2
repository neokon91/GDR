{# Emette un campo editabile dal registro core.fields.
   field('id')              -> "Label: `INPUT[...]`"
   field('id', label=false) -> "`INPUT[...]`" (solo widget, label altrove)
   Va importato con contesto: {% import '_macros.j2' as m with context %} #}
{% macro field(id, label=true) -%}
{%- set f = core.fields[id] -%}
{%- if label %}{{ f.label }}: {% endif -%}
{%- if f.widget in ['text', 'number'] -%}`INPUT[{{ f.widget }}:{{ id }}]`
{%- else -%}`INPUT[{{ f.widget }}][:{{ id }}]`{%- endif -%}
{%- endmacro %}

{# Rende i campi 'body' del wizard (core.creation[categoria]) come callout
   editabili (pre-compilati dal wizard nel frontmatter). #}
{% macro wizard_body(category) -%}
{% set wiz = core.get('creation', {}).get(category, {}) %}
{% for q in wiz.get('body', []) %}
> [!{{ q.get('callout', 'note') }}]{{ '-' if q.get('fold') else '' }} {{ q.get('title') or q.get('heading') or q.field }}
> `INPUT[textArea:{{ q.field }}]`

{% endfor %}
{%- endmacro %}
