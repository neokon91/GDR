> **{{ a.nome }}** `INPUT[slider(minValue(1), maxValue(5), addLabels):{{ a.id }}]` → {{ asse_etichetta(a) }}
{% endfor %}
{% for a in assi %}

> [!note]- {{ a.nome }}{{ (" — " ~ a.descrizione) if a.get('descrizione') else "" }}
{% for k, v in a.valori | dictsort %}
> **{{ k }} · {{ v.etichetta }}** — {{ v.get('descrizione', '') }}
{% endfor %}
{% endfor %}
{% if assi | length >= 3 %}

{{ grafico_assi(category) }}
{% endif %}
