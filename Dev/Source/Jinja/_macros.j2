{# Emette un campo editabile dal registro core.fields.
   field('id')              -> "Label: `INPUT[...]`"
   field('id', label=false) -> "`INPUT[...]`" (solo widget, label altrove)
   Va importato con contesto: {% import '_macros.j2' as m with context %} #}
{% macro field(id, label=true) -%}
{%- set f = core.fields[id] -%}
{%- if label %}{{ f.label }}: {% endif -%}
{%- if f.widget in ['text', 'number'] -%}`INPUT[{{ f.widget }}:{{ id }}]`
{%- else -%}`INPUT[{{ f.widget }}][:{{ id }}]`{%- endif -%}
{%- endmacro %}

{# ℹ️ Guida all'entità (onboarding, stile World Anvil): in UN callout pieghevole —
   cos'è/a cosa serve (scopo), come impostare i campi principali (campi_chiave) e gli
   spunti creativi. Single source: core.guida[categoria] (da entities/<x>.yaml) +
   core.spunti[categoria]. Sta in cima alla nota; aiuta chi parte, non ingombra chi sa
   già. Vuoto se l'entità non ha né guida né spunti (es. la nota generica). #}
{% macro guida(category, title='') -%}
{%- set g = core.get('guida', {}).get(category) -%}
{%- set sp = core.get('spunti', {}).get(category, []) -%}
{%- if g or sp -%}
> [!info]- ℹ️ Guida{{ (" — " ~ title) if title else "" }}
{% if g and g.get('scopo') %}> **Cos'è** · {{ g.scopo }}
{% endif %}{% if g and g.get('campi_chiave') %}> **Campi chiave** · {{ g.campi_chiave }}
{% endif %}{% if sp %}> **Spunti** · {% for s in sp %}{{ s }}{{ " " if not loop.last }}{% endfor %}
{% endif %}

{% endif -%}
{%- endmacro %}

{# Rende i campi 'body' del wizard (core.creation[categoria]) come callout
   editabili (pre-compilati dal wizard nel frontmatter). #}
{% macro wizard_body(category) -%}
{% set wiz = core.get('creation', {}).get(category, {}) %}
{% for q in wiz.get('body', []) %}
> [!{{ q.get('callout', 'note') }}]{{ '-' if q.get('fold') else '' }} {{ q.get('title') or q.get('heading') or q.field }}
> `INPUT[textArea:{{ q.field }}]`

{% endfor %}
{%- endmacro %}

{# --- Campi SOLA-LETTURA / CALCOLATI (Meta Bind VIEW) ------------------------
   Controparte read-only di field()/INPUT. Mostrano un valore senza renderlo
   editabile: utili per infobox/intestazioni che riflettono il frontmatter
   (modificato altrove). Modello: FantasyWorld JINJA/components/macro.jinja. #}

{# view('mondo') -> `VIEW[{mondo} ?? "—"]` — mostra il valore (math), "—" se vuoto. #}
{% macro view(path) -%}
`VIEW[{{ "{" ~ path ~ "}" }} ?? "—"]`
{%- endmacro %}

{# view_md('mondo') -> rende il markdown del valore (link [[..]], grassetto...). #}
{% macro view_md(path) -%}
`VIEW[{{ "{" ~ path ~ "}" }}][text(renderMarkdown)]`
{%- endmacro %}

{# dvview('classe') -> `= default(this.classe, "—")` — Dataview inline (sola lettura).
   Alternativa LEGGERA a view() per i valori STATICI (scritti una volta dal wizard,
   non rieditati a mano nella nota): non richiede Meta Bind e Dataview rende già
   link [[..]]/markdown. NON usarlo per i campi reattivi/in tabella-callout
   (infobox) — lì serve la reattività di Meta Bind VIEW. #}
{% macro dvview(path) -%}
`= default(this.{{ path }}, "—")`
{%- endmacro %}

{# Campo calcolato sola-lettura da un'espressione Meta Bind.
   computed('floor(({pressione}) / 2)') -> `VIEW[floor(({pressione}) / 2)]`.
   Riferimenti alle proprieta' tra graffe: {prop}, annidati {a.b.c}.
   Supporta ternari/confronti, es:
   computed('{pressione} >= 7 ? "Crisi" : ({pressione} >= 4 ? "Tensione" : "Calma")') #}
{% macro computed(expr) -%}
`VIEW[{{ expr }}]`
{%- endmacro %}

{# Come computed ma SALVA il risultato in 'dest' (VIEW[expr][math:dest]).
   compute_into('{forza} - 10', 'mod_forza'). #}
{% macro compute_into(expr, dest) -%}
`VIEW[{{ expr }}][math:{{ dest }}]`
{%- endmacro %}

{# === COMPONENTI CONDIVISI (DRY) =============================================
   Un'unica definizione, riusata da tutti i template. Evita il copia-incolla di
   intestazioni, superficie giocabile, collegamenti e pannelli. #}

{# Banner (cover image in testa, stile wiki/World Anvil/LegendKeeper): per le categorie
   "panoramiche" (core.banner_categorie) emette un'immagine LARGA full-width sopra il titolo,
   via lo stesso imageSuggester del ritratto; gdr.css la rende "nuda" e ritagliata a fascia.
   È UN blocco singolo full-width → robusto: niente float fra blocchi (che il renderer virtuale
   di Obsidian in lettura rompe — vedi nota in render_config). Vuoto per le altre categorie. #}
{% macro banner(template) -%}
{%- if template.category in core.get('banner_categorie', []) -%}
> [!banner]
> {{ field('banner', label=false) }}

{% endif -%}
{%- endmacro %}

{# Infobox stile wiki (intestazione sopra le tab): icona + titolo, un RITRATTO
   opzionale (immagine, solo per le categorie "visive") e una TABELLA dei fatti
   chiave — tipo/mondo/famiglia + i campi-scheda (sola lettura reattiva, VIEW),
   con lo stato editabile. I campi inline in tabella sono lo stesso pattern già
   usato e funzionante in scheda_pg_rules. Single source: core.scheda/categories. #}
{% macro identita_card(template) -%}
{%- set icon = plugins.get('folder_icons', {}).get(template.category, '') -%}
{%- set cat = core.get('categories', {}).get(template.category, {}) -%}
{%- set scheda = core.get('scheda', {}).get(template.category, []) -%}
> [!infobox|{{ template.category }}] {{ (icon ~ ' ') if icon else '' }}{{ template.title }}
{% if template.category in core.get('ritratto_categorie', []) %}
> {{ field('ritratto', label=false) }}
>
{% endif %}
> | | |
> |:--|:--|
> | **Tipo** | {{ view('tipo') }} |
{% if template.category != "mondo" %}
> | **Mondo** | {{ view_md('mondo') }} |
{% endif %}
{% if cat.get('famiglie') %}
> | **{{ cat.get('famiglia_label', 'Famiglia') }}** | {{ view('famiglia') }} |
{% endif %}
{%- set rels = core.get('relazioni', {}).get(template.category, []) -%}
{% for fid in core.get('infobox_relazioni', {}).get(template.category, []) %}
{% set r = (rels | selectattr('field', 'equalto', fid) | list | first) %}
{% if r %}
> | **{{ r.label }}** | {{ view_md(r.field) }} |
{% endif %}
{% endfor %}
{% for fid in scheda %}
> | **{{ core.fields[fid].label }}** | {{ view(fid) }} |
{% endfor %}
> | **Stato** | {{ field('stato', label=false) }} |

{{ opzioni(template) }}
{%- endmacro %}

{# Callout «⚙️ Opzioni»: le IMPOSTAZIONI editabili della nota (Meta Bind) in un posto
   solo — stato, tipo (select dai subtypes), famiglia, canonico, visibilità (dm/meta =
   escludi dal sito giocatori), rivelazione. Pieghevole; appeso a identita_card → compare
   su OGNI nota. tipo/famiglia generati come inlineSelect dai valori validi (niente typo). #}
{% macro opzioni(template) -%}
{%- set cat = core.get('categories', {}).get(template.category, {}) -%}
{%- set subs = cat.get('subtypes', []) -%}
{%- set fams = cat.get('famiglie', []) -%}
> [!opzioni]- ⚙️ Opzioni
> **Stato**: {{ field('stato', label=false) }}
{% if subs %}
> **Tipo**: `INPUT[inlineSelect({% for s in subs %}option({{ s }}){{ ', ' if not loop.last }}{% endfor %}):tipo]`
{% endif %}
{% if fams %}
> **{{ cat.get('famiglia_label', 'Famiglia') }}**: `INPUT[inlineSelect({% for f in fams %}option({{ f.nome }}){{ ', ' if not loop.last }}{% endfor %}):famiglia]`
{% endif %}
> **Canonico**: `INPUT[toggle:canonico]`
> **Visibilità** *(dm = solo DM, fuori dal sito giocatori)*: `INPUT[inlineSelect(option(normale), option(dm)):visibilita]`
> **Rivelazione**: {{ field('rivelazione', label=false) }}
{%- endmacro %}

{# Classificazione a 2 livelli (famiglia + tipo): se la categoria ha 'famiglie',
   una legenda PIEGHEVOLE auto-documentante (cosa significa ogni famiglia). Il
