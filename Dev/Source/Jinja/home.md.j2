```dataviewjs
// Cruscotti del mondo, PROGRESSIVI: ogni tabella si disegna SOLO se ha contenuto, così
// un vault vuoto non mostra 4 tabelle vuote (overload/"è rotto?"). Si popolano da sé man
// mano che crei. (Stesso approccio della spina di onboarding sopra.)
const p = dv.pages().where(x => !x.file.path.startsWith("z."));
const has = v => v != null && (!Array.isArray(v) || v.length > 0);
let shown = false;
const trame = p.where(x => has(x.alleati) || has(x.rivali)).sort(x => x.file.name, "asc");
if (trame.length) { shown = true; dv.header(2, "🤝 Trame (alleati / rivali)");
  dv.table(["Chi", "Alleati", "Rivali"], trame.map(x => [x.file.link, x.alleati, x.rivali])); }
const eventi = p.where(x => x.categoria == "evento").sort(x => x.quando, "asc");
if (eventi.length) { shown = true; dv.header(2, "Cronologia eventi");
  dv.table(["Evento", "Quando", "Mondo"], eventi.map(x => [x.file.link, x.quando, x.mondo])); }
const conCat = p.where(x => x.categoria);
if (conCat.length) { shown = true; dv.header(2, "Note per categoria");
  dv.table(["Categoria", "Note"], conCat.groupBy(x => x.categoria).sort(g => g.key, "asc").map(g => [g.key, g.rows.length])); }
const bozze = p.where(x => x.stato == "bozza" && x.categoria).sort(x => x.file.mtime, "desc").limit(20);
if (bozze.length) { shown = true; dv.header(2, "Da rifinire (bozze)");
  dv.table(["Nota", "Categoria", "Mondo"], bozze.map(x => [x.file.link, x.categoria, x.mondo])); }
if (!shown) dv.paragraph("*📊 I cruscotti del mondo (trame, cronologia, bozze) compaiono qui man mano che crei le note.*");
```

