              "display": "Iniziativa",
              "conditioned": true,
              "callback": "if (monster.initiative) return monster.initiative; const stats = Array.isArray(monster.stats) ? monster.stats : [10,10,10,10,10,10]; const dex = Number(stats[1] ?? 10); const mod = Math.floor((dex - 10) / 2); const score = 10 + mod; return `${mod >= 0 ? '+' : ''}${mod} (${score})`;"
