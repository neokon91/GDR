{
  "name": "vault-gdr",
  "version": "1.0.1",
  "private": true,
  "description": "Vault Obsidian per preparare e gestire campagne GDR fantasy in italiano.",
  "scripts": {
    "build": "npm run release:final",
    "release:final": "python3 Dev/Tools/python/release_final.py",
    "release:clean": "python3 Dev/Tools/python/release_clean.py",
