{
  "name": "vault-gdr",
  "version": "1.0.1",
  "private": true,
  "description": "Vault Obsidian per preparare e gestire campagne GDR fantasy in italiano.",
  "scripts": {
    "build": "npm run release:final",
    "release:final": "node Dev/Tools/node-legacy/release_final.js",
    "release:clean": "node Dev/Tools/node-legacy/release_clean.js",
    "sync:sources": "python3 Dev/Tools/python/run_source_pipeline.py --mode render --outputs-only",
    "clean:generated": "python3 Dev/Tools/python/clean_generated_outputs.py",
    "import:srd": "node Dev/Tools/node-legacy/import_srd.js",
    "import:map": "node Dev/Tools/node-legacy/import_map.js",
    "import:azgaar": "node Dev/Tools/node-legacy/import_azgaar_geojson.js",
    "import:watabou:city": "node Dev/Tools/node-legacy/import_watabou_city.js",
    "import:watabou:dungeon": "node Dev/Tools/node-legacy/import_watabou_dungeon.js"
  }
}
