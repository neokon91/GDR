{
  "name": "vault-gdr",
  "version": "1.0.0",
  "private": true,
  "description": "Vault Obsidian per preparare e gestire campagne GDR fantasy in italiano.",
  "scripts": {
    "check": "npm run check:source-pipeline && node z.automazioni/check_vault.js && npm run check:generation-contract && npm run check:workflow-actions && npm run check:user-path && npm run check:demo-contract && npm run check:release-artifact && npm run check:release-quality && npm run check:docs && npm run check:smoke && npm run check:m11 && npm run check:release && npm run check:importers && npm run check:repo && npm run check:js && npm run check:diff",
    "import:srd-data": "node z.automazioni/import_srd_character_data.js",
    "check:srd-character-data": "node z.automazioni/check_srd_character_data.js",
    "check:layer": "node z.automazioni/check_vault.js",
    "check:templates": "python3 z.automazioni/check_template_factory.py",
    "check:source-pipeline": "python3 z.automazioni/run_source_pipeline.py --mode check",
    "check:obsidian-config": "python3 z.automazioni/render_obsidian_config.py --check",
    "check:plugin-matrix": "python3 z.automazioni/render_plugin_matrix.py --check",
    "check:plugin-usage": "node z.automazioni/check_plugin_usage_audit.js",
    "check:templater-wrappers": "python3 z.automazioni/render_templater_wrappers.py --check",
    "check:metabind-config": "python3 z.automazioni/render_metabind_config.py --check",
    "check:generation-contract": "python3 z.automazioni/check_generation_contract.py",
    "check:workflow-data": "node z.automazioni/generate_workflow_data.js --check",
    "check:workflow-actions": "node z.automazioni/check_workflow_quick_actions.js",
    "check:workflow-render": "node z.automazioni/render_workflow_quick_actions.js --check",
    "check:validation-contract": "node z.automazioni/check_validation_contract.js",
    "check:user-path": "node z.automazioni/check_user_path.js",
    "check:metadata": "python3 z.automazioni/render_metadata_surfaces.py --check",
    "check:demo-contract": "node z.automazioni/check_demo_contract.js",
    "check:docs": "node z.automazioni/check_docs_coherence.js",
    "check:smoke": "node z.automazioni/check_smoke.js && node z.automazioni/check_runtime_load.js",
    "check:m11": "node z.automazioni/check_m11_fixture.js",
    "check:release": "node z.automazioni/check_release.js",
    "check:release-artifact": "node z.automazioni/check_release_artifact.js --with-demo",
    "check:obsidian-user": "node z.automazioni/check_obsidian_user_acceptance.js",
    "check:importers": "node z.automazioni/check_importers.js",
    "render:templates": "python3 z.automazioni/render_template_factory.py",
    "sync:sources": "python3 z.automazioni/run_source_pipeline.py --mode render",
    "render:metadata": "python3 z.automazioni/render_metadata_surfaces.py",
    "render:obsidian-config": "python3 z.automazioni/render_obsidian_config.py",
    "render:plugin-matrix": "python3 z.automazioni/render_plugin_matrix.py",
    "render:templater-wrappers": "python3 z.automazioni/render_templater_wrappers.py",
    "render:metabind-config": "python3 z.automazioni/render_metabind_config.py",
    "generate:templates": "python3 z.automazioni/render_template_factory.py --materialize",
    "generate:workflow-data": "node z.automazioni/generate_workflow_data.js",
    "render:workflow-actions": "node z.automazioni/render_workflow_quick_actions.js",
    "audit:templates": "python3 z.automazioni/audit_template_migration.py",
    "check:repo": "node z.automazioni/repo_hygiene.js",
    "check:js": "node z.automazioni/check_js.js",
    "check:diff": "git diff --check",
    "clean:repo": "node z.automazioni/repo_hygiene.js --fix",
    "generate:demo-fixture": "node z.automazioni/generate_demo_fixture.js --out dist/vault-gdr-clean --force",
    "generate:demo-world": "node z.automazioni/generate_demo_world.js --out dist/vault-gdr-clean --force",
    "import:map": "node z.automazioni/import_map.js",
    "import:srd": "node z.automazioni/import_srd.js",
    "import:azgaar": "node z.automazioni/import_azgaar_geojson.js",
    "import:watabou:city": "node z.automazioni/import_watabou_city.js",
    "import:watabou:dungeon": "node z.automazioni/import_watabou_dungeon.js",
    "release:clean": "node z.automazioni/release_clean.js",
    "release:demo": "node z.automazioni/release_clean.js --with-demo",
    "check:release-quality": "node z.automazioni/check_release_quality.js"
  }
}
